                    <!-- Admin Settings -->
                    <div id="admin-settings" class="content-section">
                        <h2>System Settings</h2>
                        <div class="card">
                            <h3>Bank Information</h3>
                            <div class="form-group">
                                <label>Bank Name</label>
                                <input type="text" value="Global Pilgrim Bank Nigeria" readonly>
                            </div>
                            <div class="form-group">
