                                <input type="text" value="GPBINGLA" readonly>
                            </div>
                            <div class="form-group">
                                <label>NIBSS Code</label>
                                <input type="text" value="999001" readonly>
                            </div>
                            <div class="form-group">
                                <label>CBN License Number</label>
                                <input type="text" value="CBN/BNK/2024/999" readonly>
                            </div>
                            <div class="form-group">
                                <label>Owner</label>
                                <input type="text" value="Olawale Abdul-ganiyu Adeshina" readonly>
                            </div>
                            <div class="owner-signature">
                                <h4>Owner Details</h4>
                                <p>Name: Olawale Abdul-ganiyu Adeshina</p>
                                <p>Age: 40</p>
                                <p>Gender: Male</p>
                                <p>Status: Single</p>
                                <p>Location: Ogun State, Nigeria</p>
                                <p>Office: Lagos, Nigeria</p>
