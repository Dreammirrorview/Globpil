    </div>

    <script>
        // ============================================
        // GLOBAL PILGRIM BANK NIGERIA - MAIN SYSTEM
        // Owner: Olawale Abdul-ganiyu Adeshina
        // ============================================

        // Database (localStorage)
        let database = {
            customers: [],
            transactions: [],
            mining: {},
            investments: [],
            bets: [],
            system: {
                bankCode: '999',
                swiftCode: 'GPBINGLA',
                nibssCode: '999001',
                cbnLicense: 'CBN/BNK/2024/999',
                owner: 'Olawale Abdul-ganiyu Adeshina',
                ownerAccount: '2345921499',
                ownerBank: 'UBA',
                ownerNIN: '87142812384',
                ownerBVN: '22203477535'
            }
        };

        // Current user
        let currentUser = null;
        let isAdmin = false;

        // Crypto currencies
        const cryptoCurrencies = [
            { code: 'BTC', name: 'Bitcoin', symbol: '₿', rate: 45000 },
            { code: 'ETH', name: 'Ethereum', symbol: 'Ξ', rate: 3200 },
            { code: 'PIL', name: 'Pilgrim Coin', symbol: 'P', rate: 1 },
            { code: 'USDT', name: 'Tether', symbol: '₮', rate: 1 },
            { code: 'BNB', name: 'Binance Coin', symbol: 'BNB', rate: 380 },
            { code: 'SOL', name: 'Solana', symbol: 'SOL', rate: 95 },
            { code: 'XRP', name: 'Ripple', symbol: 'XRP', rate: 0.55 },
            { code: 'ADA', name: 'Cardano', symbol: 'ADA', rate: 0.45 },
            { code: 'DOGE', name: 'Dogecoin', symbol: 'Ð', rate: 0.08 },
            { code: 'DOT', name: 'Polkadot', symbol: 'DOT', rate: 6.5 }
        ];

        // Fiat currencies
        const fiatCurrencies = [
            { code: 'NGN', name: 'Nigerian Naira', symbol: '₦', rate: 1 },
            { code: 'USD', name: 'US Dollar', symbol: '$', rate: 0.00064 },
            { code: 'GBP', name: 'British Pound', symbol: '£', rate: 0.00051 },
            { code: 'EUR', name: 'Euro', symbol: '€', rate: 0.00059 },
            { code: 'CNY', name: 'Chinese Yuan', symbol: '¥', rate: 0.0046 },
            { code: 'JPY', name: 'Japanese Yen', symbol: '¥', rate: 0.095 },
            { code: 'RUB', name: 'Russian Ruble', symbol: '₽', rate: 0.059 },
            { code: 'AUD', name: 'Australian Dollar', symbol: 'A$', rate: 0.00097 },
            { code: 'CAD', name: 'Canadian Dollar', symbol: 'C$', rate: 0.00087 },
            { code: 'BRL', name: 'Brazilian Real', symbol: 'R$', rate: 0.0032 },
            { code: 'ZAR', name: 'South African Rand', symbol: 'R', rate: 0.012 },
            { code: 'GHS', name: 'Ghanaian Cedi', symbol: 'GH₵', rate: 0.0040 },
            { code: 'UAH', name: 'Ukrainian Hryvnia', symbol: '₴', rate: 0.024 }
        ];

        // Bank codes
        const bankCodes = {
            '044': 'Access Bank',
            '058': 'GTBank',
            '011': 'First Bank',
            '033': 'UBA',
            '070': 'Fidelity Bank',
            '057': 'Zenith Bank',
            '050': 'Ecobank',
            '084': 'Keystone Bank',
            '221': 'Stanbic IBTC',
            '023': 'Citibank',
            '999': 'Global Pilgrim Bank'
        };

        // Initialize system
        function initSystem() {
            // Load database from localStorage
            const savedDB = localStorage.getItem('pilgrimBankDB');
            if (savedDB) {
                database = JSON.parse(savedDB);
            } else {
                // Create owner account
                createOwnerAccount();
                saveDatabase();
            }

            // Start mining
            startMining();

            // Start terminal monitoring
            startTerminalMonitoring();

            // Load betting data
            loadBettingData();

            // Log to terminal
            addTerminalLog('System initialized successfully', 'success');
            addTerminalLog('Bank Code: ' + database.system.bankCode, 'info');
            addTerminalLog('SWIFT Code: ' + database.system.swiftCode, 'info');
            addTerminalLog('Owner: ' + database.system.owner, 'info');
        }

        // Create owner account
        function createOwnerAccount() {
            const ownerAccount = {
                accountNumber: database.system.ownerAccount,
                serialNumber: generateSerialNumber(),
                name: database.system.owner,
                email: 'adeganglobal@gmail.com',
                phone: '+2348000000000',
                nin: database.system.ownerNIN,
                bvn: database.system.ownerBVN,
                dob: '1984-01-01',
                gender: 'male',
                address: 'Lagos, Nigeria',
                financial: 'business',
                pin: '123456',
                balance: {
                    NGN: 1000000000,
                    USD: 640000,
                    EUR: 590000,
                    GBP: 510000
                },
                crypto: {
                    BTC: 10,
                    ETH: 100,
                    PIL: 1000000,
                    USDT: 500000
                },
                status: 'active',
                createdAt: new Date().toISOString(),
                kycVerified: true,
                documents: []
            };

            database.customers.push(ownerAccount);
        }

        // Generate 10-digit account number
        function generateAccountNumber() {
            let accountNumber;
            do {
                accountNumber = Math.floor(1000000000 + Math.random() * 9000000000).toString();
            } while (database.customers.find(c => c.accountNumber === accountNumber));
            return accountNumber;
        }

        // Generate serial number
        function generateSerialNumber() {
            return 'GPB' + Date.now().toString(36).toUpperCase() + Math.random().toString(36).substring(2, 8).toUpperCase();
        }

        // Generate PIN
        function generatePIN() {
            return Math.floor(100000 + Math.random() * 900000).toString();
        }

        // Save database
        function saveDatabase() {
            localStorage.setItem('pilgrimBankDB', JSON.stringify(database));
        }

        // Page navigation
        function showPage(pageId) {
            document.querySelectorAll('.page').forEach(page => page.classList.remove('active'));
            document.getElementById(pageId + '-page').classList.add('active');
        }

        // Section navigation
        function showSection(sectionId) {
            document.querySelectorAll('.content-section').forEach(section => section.classList.remove('active'));
            document.getElementById(sectionId).classList.add('active');
            
            document.querySelectorAll('.sidebar-menu a').forEach(link => link.classList.remove('active'));
            event.target.classList.add('active');
        }

        // Admin section navigation
        function showAdminSection(sectionId) {
            document.querySelectorAll('.content-section').forEach(section => section.classList.remove('active'));
            document.getElementById(sectionId).classList.add('active');
            
            document.querySelectorAll('.sidebar-menu a').forEach(link => link.classList.remove('active'));
            event.target.classList.add('active');

            // Load section data
            if (sectionId === 'admin-overview') loadAdminOverview();
            if (sectionId === 'admin-customers') loadCustomers();
            if (sectionId === 'admin-transactions') loadAdminTransactions();
            if (sectionId === 'admin-approvals') loadApprovals();
            if (sectionId === 'admin-mining') loadAdminMining();
        }

        // Login form handler
        document.getElementById('login-form').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const accountNumber = document.getElementById('login-account').value;
            const pin = document.getElementById('login-pin').value;

            const customer = database.customers.find(c => c.accountNumber === accountNumber && c.pin === pin);

            if (customer) {
                if (customer.status !== 'active') {
                    showAlert('login-alert', 'Your account is not active. Please contact support.', 'error');
                    return;
                }

                currentUser = customer;
                isAdmin = false;
                showPage('customer-dashboard');
                loadCustomerDashboard();
                addTerminalLog(`Customer login: ${accountNumber}`, 'success');
            } else {
                showAlert('login-alert', 'Invalid account number or PIN', 'error');
                addTerminalLog(`Failed login attempt: ${accountNumber}`, 'error');
            }
        });

        // Admin login form handler
        document.getElementById('admin-login-form').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const username = document.getElementById('admin-username').value;
            const password = document.getElementById('admin-password').value;

            if (username === 'olawale' && password === 'pilgrimolawale') {
                currentUser = database.customers.find(c => c.accountNumber === database.system.ownerAccount);
                isAdmin = true;
                showPage('admin-dashboard');
                loadAdminOverview();
                addTerminalLog('Admin login successful', 'success');
            } else {
                showAlert('admin-login-alert', 'Invalid admin credentials', 'error');
                addTerminalLog('Failed admin login attempt', 'error');
            }
        });

        // Load customer dashboard
        function loadCustomerDashboard() {
            if (!currentUser) return;

            // Load balances
            const balanceGrid = document.getElementById('customer-balance-grid');
            balanceGrid.innerHTML = `
                <div class="balance-card">
                    <h4>Naira Balance</h4>
                    <div class="amount">₦${formatNumber(currentUser.balance.NGN || 0)}</div>
                    <div class="currency">NGN</div>
                </div>
                <div class="balance-card">
                    <h4>US Dollar</h4>
                    <div class="amount">$${formatNumber(currentUser.balance.USD || 0)}</div>
                    <div class="currency">USD</div>
                </div>
                <div class="balance-card">
                    <h4>Pilgrim Coin</h4>
                    <div class="amount">${formatNumber(currentUser.crypto.PIL || 0)} PIL</div>
                    <div class="currency">1 PIL = $1.00</div>
                </div>
                <div class="balance-card">
                    <h4>Bitcoin</h4>
                    <div class="amount">${formatNumber(currentUser.crypto.BTC || 0, 8)} BTC</div>
                    <div class="currency">≈ $${formatNumber((currentUser.crypto.BTC || 0) * 45000)}</div>
                </div>
            `;

            // Load recent transactions
            loadCustomerTransactions();

            // Load crypto wallets
            loadCryptoWallets();

            // Load mining operations
            loadMiningOperations();

            // Load profile
            loadCustomerProfile();
        }

        // Load customer transactions
        function loadCustomerTransactions() {
            const transactions = database.transactions
                .filter(t => t.from === currentUser.accountNumber || t.to === currentUser.accountNumber)
                .sort((a, b) => new Date(b.date) - new Date(a.date))
                .slice(0, 10);

            const tbody = document.querySelector('#customer-recent-transactions tbody');
            tbody.innerHTML = transactions.map(t => `
                <tr>
                    <td>${formatDate(t.date)}</td>
                    <td>${t.type}</td>
                    <td>${t.description}</td>
                    <td>${t.from === currentUser.accountNumber ? '-' : '+'}${t.currency}${formatNumber(t.amount)}</td>
                    <td><span class="badge ${t.status}">${t.status}</span></td>
                </tr>
            `).join('');
        }

        // Load crypto wallets
        function loadCryptoWallets() {
            const container = document.getElementById('crypto-wallets');
            container.innerHTML = cryptoCurrencies.map(crypto => `
                <div class="mining-card">
                    <div class="icon">${crypto.symbol}</div>
                    <h4>${crypto.name}</h4>
                    <div class="balance">${formatNumber(currentUser.crypto[crypto.code] || 0, 8)} ${crypto.code}</div>
                    <div class="wallet-address">${generateWalletAddress(currentUser.accountNumber, crypto.code)}</div>
                    <div class="barcode">
                        <div style="background: repeating-linear-gradient(90deg, #000 0px, #000 2px, #fff 2px, #fff 4px); height: 50px; width: 100%;"></div>
                    </div>
                </div>
            `).join('');
        }

        // Generate wallet address
        function generateWalletAddress(accountNumber, cryptoCode) {
            return cryptoCode.toLowerCase() + '1' + accountNumber + Math.random().toString(36).substring(2, 15) + Math.random().toString(36).substring(2, 15);
        }

        // Load mining operations
        function loadMiningOperations() {
            const container = document.getElementById('mining-operations');
            const miningCurrencies = [...cryptoCurrencies, ...fiatCurrencies];
            
            container.innerHTML = miningCurrencies.map(currency => `
                <div class="mining-card">
                    <div class="icon">${currency.symbol}</div>
                    <h4>${currency.name} Mining</h4>
                    <div class="balance">${formatNumber(currentUser.mining?.[currency.code] || 0, 8)} ${currency.code}</div>
                    <div class="status active">Mining Active</div>
                </div>
            `).join('');
        }

        // Load customer profile
        function loadCustomerProfile() {
            const container = document.getElementById('customer-profile-details');
            container.innerHTML = `
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div>
                        <h4>Personal Information</h4>
                        <p><strong>Name:</strong> ${currentUser.name}</p>
                        <p><strong>Account Number:</strong> ${currentUser.accountNumber}</p>
                        <p><strong>Serial Number:</strong> ${currentUser.serialNumber}</p>
                        <p><strong>Email:</strong> ${currentUser.email}</p>
                        <p><strong>Phone:</strong> ${currentUser.phone}</p>
                        <p><strong>Date of Birth:</strong> ${formatDate(currentUser.dob)}</p>
                        <p><strong>Gender:</strong> ${currentUser.gender}</p>
                    </div>
                    <div>
                        <h4>Account Information</h4>
                        <p><strong>NIN:</strong> ${currentUser.nin}</p>
                        <p><strong>BVN:</strong> ${currentUser.bvn}</p>
                        <p><strong>Financial Status:</strong> ${currentUser.financial}</p>
                        <p><strong>Address:</strong> ${currentUser.address}</p>
                        <p><strong>Status:</strong> <span class="badge ${currentUser.status}">${currentUser.status}</span></p>
                        <p><strong>KYC Verified:</strong> ${currentUser.kycVerified ? 'Yes' : 'No'}</p>
                        <p><strong>Registered:</strong> ${formatDate(currentUser.createdAt)}</p>
                    </div>
                </div>
            `;
        }

        // Load admin overview
        function loadAdminOverview() {
            const totalCustomers = database.customers.length;
            const totalBalanceNGN = database.customers.reduce((sum, c) => sum + (c.balance.NGN || 0), 0);
            const totalBalanceUSD = database.customers.reduce((sum, c) => sum + (c.balance.USD || 0), 0);
            const pendingTransactions = database.transactions.filter(t => t.status === 'pending').length;

            const statsGrid = document.getElementById('admin-stats');
            statsGrid.innerHTML = `
                <div class="balance-card">
                    <h4>Total Customers</h4>
                    <div class="amount">${totalCustomers}</div>
                    <div class="currency">Registered Accounts</div>
                </div>
                <div class="balance-card">
                    <h4>Total NGN Balance</h4>
                    <div class="amount">₦${formatNumber(totalBalanceNGN)}</div>
                    <div class="currency">Naira</div>
                </div>
                <div class="balance-card">
                    <h4>Total USD Balance</h4>
                    <div class="amount">$${formatNumber(totalBalanceUSD)}</div>
                    <div class="currency">US Dollars</div>
                </div>
                <div class="balance-card">
                    <h4>Pending Transactions</h4>
                    <div class="amount">${pendingTransactions}</div>
                    <div class="currency">Awaiting Approval</div>
                </div>
            `;
        }

        // Load customers table
        function loadCustomers() {
            const tbody = document.querySelector('#customers-table tbody');
            tbody.innerHTML = database.customers.map(customer => `
                <tr>
                    <td>${customer.accountNumber}</td>
                    <td>${customer.serialNumber}</td>
                    <td>${customer.name}</td>
                    <td>${customer.email}</td>
                    <td>${customer.phone}</td>
                    <td>₦${formatNumber(customer.balance.NGN || 0)}</td>
                    <td><span class="badge ${customer.status}">${customer.status}</span></td>
                    <td>
                        <button onclick="viewCustomer('${customer.accountNumber}')" style="padding: 5px 10px; margin: 2px;">View</button>
                        <button onclick="editCustomer('${customer.accountNumber}')" style="padding: 5px 10px; margin: 2px;">Edit</button>
                        <button onclick="deleteCustomer('${customer.accountNumber}')" style="padding: 5px 10px; margin: 2px; background: #e74c3c; color: #fff; border: none;">Delete</button>
                    </td>
                </tr>
            `).join('');
        }

        // Create customer form handler
        document.getElementById('create-customer-form').addEventListener('submit', function(e) {
            e.preventDefault();

            const nin = document.getElementById('customer-nin').value;
            const bvn = document.getElementById('customer-bvn').value;
            const phone = document.getElementById('customer-phone').value;

            // Check if NIN, BVN, or phone already exists
            const existingCustomer = database.customers.find(c => 
                c.nin === nin || c.bvn === bvn || c.phone === phone
            );

            if (existingCustomer) {
                alert('Customer with this NIN, BVN, or phone number already exists!');
                return;
            }

            const newCustomer = {
                accountNumber: generateAccountNumber(),
                serialNumber: generateSerialNumber(),
                name: document.getElementById('customer-name').value,
                dob: document.getElementById('customer-dob').value,
                gender: document.getElementById('customer-gender').value,
                email: document.getElementById('customer-email').value,
                phone: phone,
                nin: nin,
                bvn: bvn,
                address: document.getElementById('customer-address').value,
                financial: document.getElementById('customer-financial').value,
                pin: generatePIN(),
                balance: {
                    NGN: parseFloat(document.getElementById('customer-deposit').value) || 0,
                    USD: 0,
                    EUR: 0,
                    GBP: 0
                },
                crypto: {
                    BTC: 0,
                    ETH: 0,
                    PIL: 0,
                    USDT: 0
                },
                mining: {},
                status: 'active',
                createdAt: new Date().toISOString(),
                kycVerified: true,
                documents: []
            };

            database.customers.push(newCustomer);
            saveDatabase();

            alert(`Account created successfully!\n\nAccount Number: ${newCustomer.accountNumber}\nSerial Number: ${newCustomer.serialNumber}\nPIN: ${newCustomer.pin}\n\nPlease share these credentials with the customer.`);
            
            // Reset form
            this.reset();
            
            // Log to terminal
            addTerminalLog(`New customer created: ${newCustomer.accountNumber} - ${newCustomer.name}`, 'success');
        });

        // Local transfer form handler
        document.getElementById('local-transfer-form').addEventListener('submit', function(e) {
            e.preventDefault();

            const bankCode = document.getElementById('transfer-bank').value;
            const accountNumber = document.getElementById('transfer-account').value;
            const amount = parseFloat(document.getElementById('transfer-amount').value);
            const narration = document.getElementById('transfer-narration').value;

            if (amount > (currentUser.balance.NGN || 0)) {
                alert('Insufficient balance!');
                return;
            }

            // Check if it's internal transfer
            if (bankCode === '999') {
                const recipient = database.customers.find(c => c.accountNumber === accountNumber);
                if (!recipient) {
                    alert('Recipient account not found!');
                    return;
                }

                // Perform transfer
                currentUser.balance.NGN -= amount;
                recipient.balance.NGN += amount;

                // Record transaction
                const transaction = {
                    reference: generateReference(),
                    date: new Date().toISOString(),
                    from: currentUser.accountNumber,
                    to: accountNumber,
                    amount: amount,
                    currency: 'NGN',
                    type: 'transfer',
                    description: narration || 'Transfer',
                    status: 'completed'
                };

                database.transactions.push(transaction);
                saveDatabase();

                alert('Transfer successful!');
                loadCustomerDashboard();
                addTerminalLog(`Transfer: ${currentUser.accountNumber} → ${accountNumber}, ₦${amount}`, 'success');
            } else {
                // External transfer - would need payment switch integration
                alert('External transfer initiated. Processing through payment switch...');
                
                const transaction = {
                    reference: generateReference(),
                    date: new Date().toISOString(),
                    from: currentUser.accountNumber,
                    to: accountNumber,
                    bankCode: bankCode,
                    bankName: bankCodes[bankCode],
                    amount: amount,
                    currency: 'NGN',
                    type: 'external_transfer',
                    description: narration || 'External Transfer',
                    status: 'pending'
                };

                database.transactions.push(transaction);
                saveDatabase();

                // Simulate payment switch processing
                setTimeout(() => {
                    transaction.status = 'completed';
                    currentUser.balance.NGN -= amount;
                    saveDatabase();
                    addTerminalLog(`External transfer completed: ${transaction.reference}`, 'success');
                }, 3000);
            }
        });

        // International transfer form handler
        document.getElementById('international-transfer-form').addEventListener('submit', function(e) {
            e.preventDefault();

            const country = document.getElementById('intl-country').value;
            const swift = document.getElementById('intl-swift').value;
            const iban = document.getElementById('intl-iban').value;
            const name = document.getElementById('intl-name').value;
            const amount = parseFloat(document.getElementById('intl-amount').value);

            if (amount > (currentUser.balance.USD || 0)) {
                alert('Insufficient USD balance!');
                return;
            }

            // Create transaction
            const transaction = {
                reference: generateReference(),
                date: new Date().toISOString(),
                from: currentUser.accountNumber,
                to: iban,
                beneficiaryName: name,
                swiftCode: swift,
                country: country,
                amount: amount,
                currency: 'USD',
                type: 'international_transfer',
                description: 'International Wire Transfer',
                status: 'pending'
            };

            database.transactions.push(transaction);
            saveDatabase();

            alert('International transfer initiated. Processing through SWIFT network...');
            addTerminalLog(`SWIFT transfer initiated: ${transaction.reference}`, 'info');

            // Simulate SWIFT processing
            setTimeout(() => {
                transaction.status = 'completed';
                currentUser.balance.USD -= amount;
                saveDatabase();
                addTerminalLog(`SWIFT transfer completed: ${transaction.reference}`, 'success');
            }, 5000);
        });

        // Account name lookup
        document.getElementById('transfer-account').addEventListener('input', function() {
            const accountNumber = this.value;
            const bankCode = document.getElementById('transfer-bank').value;

            if (bankCode === '999' && accountNumber.length === 10) {
                const customer = database.customers.find(c => c.accountNumber === accountNumber);
                document.getElementById('transfer-name').value = customer ? customer.name : 'Account not found';
            }
        });

        // Load admin transactions
        function loadAdminTransactions() {
            const tbody = document.querySelector('#admin-transactions-table tbody');
            tbody.innerHTML = database.transactions.slice(-50).reverse().map(t => `
                <tr>
                    <td>${t.reference}</td>
                    <td>${formatDate(t.date)}</td>
                    <td>${t.from}</td>
                    <td>${t.to}</td>
                    <td>${t.currency}${formatNumber(t.amount)}</td>
                    <td>${t.type}</td>
                    <td><span class="badge ${t.status}">${t.status}</span></td>
                    <td>
                        ${t.status === 'pending' ? `<button onclick="approveTransaction('${t.reference}')" style="padding: 5px 10px;">Approve</button>` : ''}
                    </td>
                </tr>
            `).join('');
        }

        // Load approvals
        function loadApprovals() {
            const pendingTransactions = database.transactions.filter(t => t.status === 'pending');
            const tbody = document.querySelector('#approvals-table tbody');
            
            if (pendingTransactions.length === 0) {
                tbody.innerHTML = '<tr><td colspan="4">No pending approvals</td></tr>';
                return;
            }

            tbody.innerHTML = pendingTransactions.map(t => `
                <tr>
                    <td>${t.type}</td>
                    <td>${t.description} - ${t.currency}${formatNumber(t.amount)}</td>
                    <td>${formatDate(t.date)}</td>
                    <td>
                        <button onclick="approveTransaction('${t.reference}')" style="padding: 5px 10px; background: #27ae60; color: #fff; border: none; margin-right: 5px;">Approve</button>
                        <button onclick="rejectTransaction('${t.reference}')" style="padding: 5px 10px; background: #e74c3c; color: #fff; border: none;">Reject</button>
                    </td>
                </tr>
            `).join('');
        }

        // Approve transaction
        function approveTransaction(reference) {
            const transaction = database.transactions.find(t => t.reference === reference);
            if (transaction) {
                transaction.status = 'completed';
                saveDatabase();
                loadApprovals();
                loadAdminTransactions();
                addTerminalLog(`Transaction approved: ${reference}`, 'success');
            }
        }

        // Reject transaction
        function rejectTransaction(reference) {
            const transaction = database.transactions.find(t => t.reference === reference);
            if (transaction) {
                transaction.status = 'failed';
                saveDatabase();
                loadApprovals();
                loadAdminTransactions();
                addTerminalLog(`Transaction rejected: ${reference}`, 'error');
            }
        }

        // Load admin mining
        function loadAdminMining() {
            const container = document.getElementById('admin-mining-grid');
            const miningCurrencies = [...cryptoCurrencies, ...fiatCurrencies];
            
            container.innerHTML = miningCurrencies.map(currency => `
                <div class="mining-card">
                    <div class="icon">${currency.symbol}</div>
                    <h4>${currency.name}</h4>
                    <div class="balance">${formatNumber(database.mining[currency.code] || 0, 8)} ${currency.code}</div>
                    <div class="status active">Mining Active</div>
                </div>
            `).join('');
        }

        // Start mining
        function startMining() {
            setInterval(() => {
                database.customers.forEach(customer => {
                    if (!customer.mining) customer.mining = {};
                    
                    // Mine Pilgrim Coin
                    const pilMining = 0.000000001;
                    customer.mining.PIL = (customer.mining.PIL || 0) + pilMining;
                    
                    if (customer.mining.PIL >= 1) {
                        customer.crypto.PIL = (customer.crypto.PIL || 0) + Math.floor(customer.mining.PIL);
                        customer.mining.PIL = customer.mining.PIL % 1;
                    }

                    // Mine other currencies (smaller amounts)
                    cryptoCurrencies.forEach(crypto => {
                        if (crypto.code !== 'PIL') {
                            const miningAmount = pilMining * (crypto.rate / 45000);
                            customer.mining[crypto.code] = (customer.mining[crypto.code] || 0) + miningAmount;
                            
                            if (customer.mining[crypto.code] >= 0.00000001) {
                                customer.crypto[crypto.code] = (customer.crypto[crypto.code] || 0) + customer.mining[crypto.code];
                                customer.mining[crypto.code] = 0;
                            }
                        }
                    });

                    // Mine fiat currencies
                    fiatCurrencies.forEach(currency => {
                        if (currency.code !== 'NGN') {
                            const miningAmount = pilMining * currency.rate;
                            customer.mining[currency.code] = (customer.mining[currency.code] || 0) + miningAmount;
                            
                            if (customer.mining[currency.code] >= 0.01) {
                                customer.balance[currency.code] = (customer.balance[currency.code] || 0) + customer.mining[currency.code];
                                customer.mining[currency.code] = 0;
                            }
                        }
                    });
                });

                saveDatabase();
            }, 1000);
        }

        // Load betting data
        function loadBettingData() {
            const matches = [
                { id: 1, home: 'Manchester United', away: 'Liverpool', time: '15:00', odds: { home: 2.50, draw: 3.20, away: 2.80 } },
                { id: 2, home: 'Arsenal', away: 'Chelsea', time: '17:30', odds: { home: 1.85, draw: 3.50, away: 4.00 } },
                { id: 3, home: 'Barcelona', away: 'Real Madrid', time: '20:00', odds: { home: 2.20, draw: 3.40, away: 3.10 } },
                { id: 4, home: 'Bayern Munich', away: 'Dortmund', time: '18:30', odds: { home: 1.65, draw: 4.00, away: 5.00 } },
                { id: 5, home: 'Juventus', away: 'AC Milan', time: '19:45', odds: { home: 2.10, draw: 3.30, away: 3.40 } },
                { id: 6, home: 'PSG', away: 'Marseille', time: '21:00', odds: { home: 1.55, draw: 4.20, away: 5.50 } }
            ];

            const container = document.getElementById('live-matches');
            container.innerHTML = matches.map(match => `
                <div class="match-card">
                    <div class="teams">
                        <div class="team">
                            <h4>${match.home}</h4>
                        </div>
                        <div class="vs">VS</div>
                        <div class="team">
                            <h4>${match.away}</h4>
                        </div>
                    </div>
                    <p style="text-align: center; color: #e94560;">${match.time}</p>
                    <div class="odds">
                        <div class="odd" onclick="placeBet(${match.id}, 'home', ${match.odds.home})">
                            <div>1</div>
                            <div>${match.odds.home.toFixed(2)}</div>
                        </div>
                        <div class="odd" onclick="placeBet(${match.id}, 'draw', ${match.odds.draw})">
                            <div>X</div>
                            <div>${match.odds.draw.toFixed(2)}</div>
                        </div>
                        <div class="odd" onclick="placeBet(${match.id}, 'away', ${match.odds.away})">
                            <div>2</div>
                            <div>${match.odds.away.toFixed(2)}</div>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        // Place bet
        function placeBet(matchId, selection, odds) {
            const amount = prompt('Enter bet amount (NGN):');
            if (!amount) return;

            const betAmount = parseFloat(amount);
            if (betAmount > (currentUser.balance.NGN || 0)) {
                alert('Insufficient balance!');
                return;
            }

            currentUser.balance.NGN -= betAmount;

            const bet = {
                id: Date.now(),
                matchId: matchId,
                selection: selection,
                odds: odds,
                amount: betAmount,
                potentialWin: betAmount * odds,
                status: 'pending',
                createdAt: new Date().toISOString()
            };

            database.bets.push(bet);
            saveDatabase();

            alert(`Bet placed successfully!\n\nPotential Win: ₦${formatNumber(bet.potentialWin)}`);
            loadCustomerDashboard();
            addTerminalLog(`Bet placed: ₦${betAmount} at ${odds}x`, 'info');
        }

        // Select investment
        function selectInvestment(type) {
            const amount = prompt('Enter investment amount (NGN):');
            if (!amount) return;

            const investmentAmount = parseFloat(amount);
            if (investmentAmount > (currentUser.balance.NGN || 0)) {
                alert('Insufficient balance!');
                return;
            }

            currentUser.balance.NGN -= investmentAmount;

            const investment = {
                id: Date.now(),
                type: type,
                amount: investmentAmount,
                startDate: new Date().toISOString(),
                endDate: new Date(Date.now() + 5 * 365 * 24 * 60 * 60 * 1000).toISOString(),
                status: 'active'
            };

            database.investments.push(investment);
            saveDatabase();

            // Create mailto link
            const subject = `Investment Registration - ${currentUser.serialNumber}`;
            const body = `
Dear Admin,

I would like to register for ${type} investment.

Details:
- Serial Number: ${currentUser.serialNumber}
- Account Number: ${currentUser.accountNumber}
- Name: ${currentUser.name}
- Investment Type: ${type}
- Amount: ₦${formatNumber(investmentAmount)}
- Email: ${currentUser.email}

Please process my investment.

Best regards,
${currentUser.name}
            `;

            window.location.href = `mailto:adeganglobal@gmail.com,pilgrimshares@gmail.com,adeganglobalbank@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

            alert('Investment registered! Please check your email to complete the process.');
            loadCustomerDashboard();
            addTerminalLog(`Investment registered: ${type} - ₦${investmentAmount}`, 'success');
        }

        // Terminal monitoring
        function startTerminalMonitoring() {
            // Get IP and location
            fetch('https://api.ipify.org?format=json')
                .then(response => response.json())
                .then(data => {
                    addTerminalLog(`IP Address: ${data.ip}`, 'info');
                    addTerminalLog(`Connection: Secure`, 'success');
                })
                .catch(() => {
                    addTerminalLog('IP detection: Using local connection', 'warning');
                });

            // Monitor for suspicious activity
            setInterval(() => {
                const now = new Date();
                addTerminalLog(`System check: ${now.toLocaleString()}`, 'info');
            }, 60000);
        }

        // Add terminal log
        function addTerminalLog(message, type = 'info') {
            const terminal = document.getElementById('system-terminal') || document.getElementById('admin-terminal-output');
            if (terminal) {
                const line = document.createElement('div');
                line.className = `terminal-line ${type}`;
                line.textContent = `[${new Date().toLocaleTimeString()}] ${message}`;
                terminal.appendChild(line);
                terminal.scrollTop = terminal.scrollHeight;
            }
        }

        // Search customers
        function searchCustomers() {
            const query = document.getElementById('search-customer').value.toLowerCase();
            const filtered = database.customers.filter(c => 
                c.accountNumber.includes(query) ||
                c.name.toLowerCase().includes(query) ||
                c.phone.includes(query)
            );

            const tbody = document.querySelector('#customers-table tbody');
            tbody.innerHTML = filtered.map(customer => `
                <tr>
                    <td>${customer.accountNumber}</td>
                    <td>${customer.serialNumber}</td>
                    <td>${customer.name}</td>
                    <td>${customer.email}</td>
                    <td>${customer.phone}</td>
                    <td>₦${formatNumber(customer.balance.NGN || 0)}</td>
                    <td><span class="badge ${customer.status}">${customer.status}</span></td>
                    <td>
                        <button onclick="viewCustomer('${customer.accountNumber}')" style="padding: 5px 10px; margin: 2px;">View</button>
                        <button onclick="editCustomer('${customer.accountNumber}')" style="padding: 5px 10px; margin: 2px;">Edit</button>
                        <button onclick="deleteCustomer('${customer.accountNumber}')" style="padding: 5px 10px; margin: 2px; background: #e74c3c; color: #fff; border: none;">Delete</button>
                    </td>
                </tr>
            `).join('');
        }

        // View customer
        function viewCustomer(accountNumber) {
            const customer = database.customers.find(c => c.accountNumber === accountNumber);
            if (!customer) return;

            const modalBody = document.getElementById('modal-body');
            modalBody.innerHTML = `
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div>
                        <h4>Personal Information</h4>
                        <p><strong>Name:</strong> ${customer.name}</p>
                        <p><strong>Account Number:</strong> ${customer.accountNumber}</p>
                        <p><strong>Serial Number:</strong> ${customer.serialNumber}</p>
                        <p><strong>Email:</strong> ${customer.email}</p>
                        <p><strong>Phone:</strong> ${customer.phone}</p>
                        <p><strong>Date of Birth:</strong> ${formatDate(customer.dob)}</p>
                        <p><strong>Gender:</strong> ${customer.gender}</p>
                    </div>
                    <div>
                        <h4>Account Information</h4>
                        <p><strong>NIN:</strong> ${customer.nin}</p>
                        <p><strong>BVN:</strong> ${customer.bvn}</p>
                        <p><strong>Financial Status:</strong> ${customer.financial}</p>
                        <p><strong>Address:</strong> ${customer.address}</p>
                        <p><strong>Status:</strong> <span class="badge ${customer.status}">${customer.status}</span></p>
                        <p><strong>KYC Verified:</strong> ${customer.kycVerified ? 'Yes' : 'No'}</p>
                        <p><strong>Registered:</strong> ${formatDate(customer.createdAt)}</p>
                    </div>
                </div>
                <div style="margin-top: 20px;">
                    <h4>Account Balances</h4>
                    <p><strong>NGN:</strong> ₦${formatNumber(customer.balance.NGN || 0)}</p>
                    <p><strong>USD:</strong> $${formatNumber(customer.balance.USD || 0)}</p>
                    <p><strong>Pilgrim Coin:</strong> ${formatNumber(customer.crypto.PIL || 0)} PIL</p>
                </div>
            `;

            document.getElementById('modal-title').textContent = 'Customer Details';
            document.getElementById('modal').classList.add('active');
        }

        // Edit customer
        function editCustomer(accountNumber) {
            const customer = database.customers.find(c => c.accountNumber === accountNumber);
            if (!customer) return;

            const modalBody = document.getElementById('modal-body');
            modalBody.innerHTML = `
                <form id="edit-customer-form">
                    <div class="form-group">
                        <label>Name</label>
                        <input type="text" id="edit-name" value="${customer.name}" required>
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" id="edit-email" value="${customer.email}" required>
                    </div>
                    <div class="form-group">
                        <label>Phone</label>
                        <input type="tel" id="edit-phone" value="${customer.phone}" required>
                    </div>
                    <div class="form-group">
                        <label>Address</label>
                        <input type="text" id="edit-address" value="${customer.address}" required>
                    </div>
                    <div class="form-group">
                        <label>NGN Balance</label>
                        <input type="number" id="edit-balance" value="${customer.balance.NGN || 0}" required>
                    </div>
                    <div class="form-group">
                        <label>Status</label>
                        <select id="edit-status" required>
                            <option value="active" ${customer.status === 'active' ? 'selected' : ''}>Active</option>
                            <option value="suspended" ${customer.status === 'suspended' ? 'selected' : ''}>Suspended</option>
                            <option value="closed" ${customer.status === 'closed' ? 'selected' : ''}>Closed</option>
                        </select>
                    </div>
                    <button type="submit" class="btn-submit">Save Changes</button>
                </form>
            `;

            document.getElementById('modal-title').textContent = 'Edit Customer';
            document.getElementById('modal').classList.add('active');

            document.getElementById('edit-customer-form').addEventListener('submit', function(e) {
                e.preventDefault();

                customer.name = document.getElementById('edit-name').value;
                customer.email = document.getElementById('edit-email').value;
                customer.phone = document.getElementById('edit-phone').value;
                customer.address = document.getElementById('edit-address').value;
                customer.balance.NGN = parseFloat(document.getElementById('edit-balance').value);
                customer.status = document.getElementById('edit-status').value;

                saveDatabase();
                closeModal();
                loadCustomers();
                alert('Customer updated successfully!');
                addTerminalLog(`Customer updated: ${accountNumber}`, 'success');
            });
        }

        // Delete customer
        function deleteCustomer(accountNumber) {
            const password = prompt('Enter admin password to delete this customer:');
            if (password !== 'pilgrimolawale') {
                alert('Invalid password!');
                return;
            }

            if (confirm('Are you sure you want to delete this customer? This action cannot be undone.')) {
                const index = database.customers.findIndex(c => c.accountNumber === accountNumber);
                if (index > -1) {
                    database.customers.splice(index, 1);
                    saveDatabase();
                    loadCustomers();
                    alert('Customer deleted successfully!');
                    addTerminalLog(`Customer deleted: ${accountNumber}`, 'warning');
                }
            }
        }

        // Close modal
        function closeModal() {
            document.getElementById('modal').classList.remove('active');
        }

        // Show alert
        function showAlert(elementId, message, type) {
            const alert = document.getElementById(elementId);
            alert.textContent = message;
            alert.className = `alert ${type} active`;
            setTimeout(() => {
                alert.classList.remove('active');
            }, 5000);
        }

        // Show forgot password
        function showForgotPassword() {
            const email = prompt('Enter your email address:');
            if (email) {
                const customer = database.customers.find(c => c.email === email);
                if (customer) {
                    alert(`Your PIN is: ${customer.pin}`);
                } else {
                    alert('Email not found!');
                }
            }
        }

        // Logout
        function logout() {
            currentUser = null;
            isAdmin = false;
            showPage('login');
            addTerminalLog('User logged out', 'info');
        }

        // Generate reference
        function generateReference() {
            return 'GPB' + Date.now().toString(36).toUpperCase() + Math.random().toString(36).substring(2, 8).toUpperCase();
        }

        // Format number
        function formatNumber(num, decimals = 2) {
            return parseFloat(num || 0).toLocaleString('en-US', {
                minimumFractionDigits: decimals,
                maximumFractionDigits: decimals
            });
        }

        // Format date
        function formatDate(dateStr) {
            return new Date(dateStr).toLocaleDateString('en-NG', {
                year: 'numeric',
                month: 'short',
                day: 'numeric'
            });
        }

        // Initialize on load
        window.onload = function() {
            initSystem();
        };
    </script>
</body>
</html>