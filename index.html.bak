<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global Pilgrim Bank Nigeria - Digital Banking Ecosystem</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            min-height: 100vh;
            color: #fff;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px;
        }

        /* Header */
        .header {
            background: linear-gradient(90deg, #0f3460 0%, #1a1a2e 100%);
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo img {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            border: 3px solid #e94560;
        }

        .logo h1 {
            font-size: 24px;
            color: #e94560;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        }

        .logo p {
            font-size: 12px;
            color: #fff;
        }

        .nav-buttons {
            display: flex;
            gap: 10px;
        }

        .nav-btn {
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s;
        }

        .nav-btn.primary {
            background: #e94560;
            color: #fff;
        }

        .nav-btn.secondary {
            background: #0f3460;
            color: #fff;
            border: 1px solid #e94560;
        }

        .nav-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(233,69,96,0.3);
        }

        /* Pages */
        .page {
            display: none;
            animation: fadeIn 0.5s;
        }

        .page.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Login Page */
        .login-container {
            max-width: 500px;
            margin: 50px auto;
            background: rgba(255,255,255,0.1);
            padding: 40px;
            border-radius: 15px;
            backdrop-filter: blur(10px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        }

        .login-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .login-header h2 {
            color: #e94560;
            font-size: 28px;
            margin-bottom: 10px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #fff;
            font-weight: 500;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 12px;
            border: 2px solid #0f3460;
            border-radius: 5px;
            background: rgba(255,255,255,0.1);
            color: #fff;
            font-size: 16px;
            transition: all 0.3s;
        }

        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: #e94560;
            box-shadow: 0 0 10px rgba(233,69,96,0.3);
        }

        .form-group input::placeholder {
            color: rgba(255,255,255,0.5);
        }

        .btn-submit {
            width: 100%;
            padding: 15px;
            background: linear-gradient(90deg, #e94560 0%, #ff6b6b 100%);
            border: none;
            border-radius: 5px;
            color: #fff;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(233,69,96,0.4);
        }

        .forgot-password {
            text-align: center;
            margin-top: 15px;
        }

        .forgot-password a {
            color: #e94560;
            text-decoration: none;
        }

        .forgot-password a:hover {
            text-decoration: underline;
        }

        /* Dashboard */
        .dashboard {
            display: grid;
            grid-template-columns: 250px 1fr;
            gap: 20px;
            min-height: calc(100vh - 150px);
        }

        .sidebar {
            background: rgba(255,255,255,0.1);
            padding: 20px;
            border-radius: 10px;
            backdrop-filter: blur(10px);
        }

        .sidebar-menu {
            list-style: none;
        }

        .sidebar-menu li {
            margin-bottom: 10px;
        }

        .sidebar-menu a {
            display: block;
            padding: 12px 15px;
            color: #fff;
            text-decoration: none;
            border-radius: 5px;
            transition: all 0.3s;
        }

        .sidebar-menu a:hover,
        .sidebar-menu a.active {
            background: #e94560;
            transform: translateX(5px);
        }

        .main-content {
            background: rgba(255,255,255,0.1);
            padding: 20px;
            border-radius: 10px;
            backdrop-filter: blur(10px);
        }

        .content-section {
            display: none;
        }

        .content-section.active {
            display: block;
        }

        /* Cards */
        .card {
            background: rgba(255,255,255,0.05);
            padding: 20px;
            border-radius: 10px;
            margin-bottom: 20px;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .card h3 {
            color: #e94560;
            margin-bottom: 15px;
            font-size: 20px;
        }

        /* Balance Cards */
        .balance-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .balance-card {
            background: linear-gradient(135deg, #0f3460 0%, #1a1a2e 100%);
            padding: 25px;
            border-radius: 10px;
            border-left: 4px solid #e94560;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }

        .balance-card h4 {
            color: #fff;
            font-size: 14px;
            margin-bottom: 10px;
            opacity: 0.8;
        }

        .balance-card .amount {
            color: #e94560;
            font-size: 32px;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .balance-card .currency {
            color: #fff;
            font-size: 14px;
            opacity: 0.6;
        }

        /* Tables */
        .table-container {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

        th, td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        th {
            background: rgba(233,69,96,0.2);
            color: #e94560;
            font-weight: 600;
        }

        tr:hover {
            background: rgba(255,255,255,0.05);
        }

        /* Status Badges */
        .badge {
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .badge.success {
            background: #27ae60;
            color: #fff;
        }

        .badge.pending {
            background: #f39c12;
            color: #fff;
        }

        .badge.failed {
            background: #e74c3c;
            color: #fff;
        }

        /* Terminal */
        .terminal {
            background: #000;
            padding: 20px;
            border-radius: 10px;
            font-family: 'Courier New', monospace;
            color: #0f0;
            height: 300px;
            overflow-y: auto;
            border: 2px solid #e94560;
            margin-top: 20px;
        }

        .terminal-line {
            margin-bottom: 5px;
        }

        .terminal-line.error {
            color: #e74c3c;
        }

        .terminal-line.warning {
            color: #f39c12;
        }

        .terminal-line.success {
            color: #27ae60;
        }

        /* Mining Section */
        .mining-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-top: 20px;
        }

        .mining-card {
            background: rgba(255,255,255,0.05);
            padding: 20px;
            border-radius: 10px;
            text-align: center;
            border: 1px solid rgba(255,255,255,0.1);
            transition: all 0.3s;
        }

        .mining-card:hover {
            transform: translateY(-5px);
            border-color: #e94560;
        }

        .mining-card .icon {
            font-size: 40px;
            margin-bottom: 10px;
        }

        .mining-card h4 {
            color: #fff;
            margin-bottom: 5px;
        }

        .mining-card .balance {
            color: #e94560;
            font-size: 18px;
            font-weight: bold;
        }

        .mining-card .status {
            font-size: 12px;
            margin-top: 10px;
            padding: 5px;
            border-radius: 5px;
        }

        .mining-card .status.active {
            background: #27ae60;
            color: #fff;
        }

        .mining-card .status.inactive {
            background: #e74c3c;
            color: #fff;
        }

        /* Betting Section */
        .betting-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .match-card {
            background: rgba(255,255,255,0.05);
            padding: 20px;
            border-radius: 10px;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .match-card .teams {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .match-card .team {
            text-align: center;
            flex: 1;
        }

        .match-card .team h4 {
            color: #fff;
            margin-bottom: 5px;
        }

        .match-card .vs {
            color: #e94560;
            font-weight: bold;
            font-size: 18px;
        }

        .match-card .odds {
            display: flex;
            justify-content: space-around;
            margin-top: 15px;
        }

        .match-card .odd {
            background: rgba(233,69,96,0.2);
            padding: 10px 20px;
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .match-card .odd:hover {
            background: #e94560;
        }

        /* Investment Section */
        .investment-options {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .investment-card {
            background: linear-gradient(135deg, #0f3460 0%, #1a1a2e 100%);
            padding: 25px;
            border-radius: 10px;
            border: 2px solid transparent;
            transition: all 0.3s;
            cursor: pointer;
        }

        .investment-card:hover {
            border-color: #e94560;
            transform: translateY(-5px);
        }

        .investment-card h4 {
            color: #e94560;
            font-size: 20px;
            margin-bottom: 10px;
        }

        .investment-card .roi {
            color: #27ae60;
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .investment-card .duration {
            color: #fff;
            opacity: 0.8;
            font-size: 14px;
        }

        /* Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            padding: 30px;
            border-radius: 15px;
            max-width: 600px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
            border: 2px solid #e94560;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .modal-header h3 {
            color: #e94560;
        }

        .close-modal {
            background: none;
            border: none;
            color: #fff;
            font-size: 24px;
            cursor: pointer;
        }

        /* Alert */
        .alert {
            padding: 15px;
            border-radius: 5px;
            margin-bottom: 20px;
            display: none;
        }

        .alert.active {
            display: block;
        }

        .alert.success {
            background: #27ae60;
            color: #fff;
        }

        .alert.error {
            background: #e74c3c;
            color: #fff;
        }

        .alert.warning {
            background: #f39c12;
            color: #fff;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .dashboard {
                grid-template-columns: 1fr;
            }

            .sidebar {
                display: none;
            }

            .header {
                flex-direction: column;
                gap: 15px;
            }

            .nav-buttons {
                flex-wrap: wrap;
                justify-content: center;
            }
        }

        /* Owner Signature */
        .owner-signature {
            text-align: center;
            padding: 20px;
            background: rgba(233,69,96,0.1);
            border-radius: 10px;
            margin-top: 20px;
        }

        .owner-signature h4 {
            color: #e94560;
            margin-bottom: 10px;
        }

        .owner-signature p {
            color: #fff;
            opacity: 0.8;
        }

        /* Security Alert */
        .security-alert {
            background: linear-gradient(90deg, #e74c3c 0%, #c0392b 100%);
            padding: 15px;
            border-radius: 5px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .security-alert .icon {
            font-size: 24px;
        }

        /* Loading */
        .loading {
            display: none;
            text-align: center;
            padding: 20px;
        }

        .loading.active {
            display: block;
        }

        .spinner {
            border: 4px solid rgba(255,255,255,0.1);
            border-top: 4px solid #e94560;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto 10px;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Crypto Wallet */
        .wallet-address {
            background: rgba(0,0,0,0.3);
            padding: 10px;
            border-radius: 5px;
            font-family: 'Courier New', monospace;
            font-size: 12px;
            word-break: break-all;
            margin-top: 10px;
            color: #e94560;
        }

        /* Barcode */
        .barcode {
            background: #fff;
            padding: 10px;
            border-radius: 5px;
            margin-top: 10px;
            text-align: center;
        }

        .barcode img {
            max-width: 100%;
            height: auto;
        }
    </style>
<script src="https://sites.super.myninja.ai/_assets/ninja-daytona-script.js"></script>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <div class="logo">
                <img src="IMG_20251020_081844.jpg" alt="Olawale Abdul-ganiyu Adeshina">
                <div>
                    <h1>Global Pilgrim Bank Nigeria</h1>
                    <p>Hope Like We Make Future | Mother Bank</p>
                    <p>Owner: Olawale Abdul-ganiyu Adeshina</p>
                </div>
            </div>
            <div class="nav-buttons">
                <button class="nav-btn primary" onclick="showPage('login')">Login</button>
                <button class="nav-btn secondary" onclick="showPage('admin-login')">Admin</button>
            </div>
        </div>

        <!-- Login Page -->
        <div id="login-page" class="page active">
            <div class="login-container">
                <div class="login-header">
                    <h2>Customer Login</h2>
                    <p>Global Pilgrim Bank Nigeria</p>
                </div>
                <div class="alert" id="login-alert"></div>
                <form id="login-form">
                    <div class="form-group">
                        <label>Account Number</label>
                        <input type="text" id="login-account" placeholder="Enter 10-digit account number" maxlength="10" required>
                    </div>
                    <div class="form-group">
                        <label>PIN</label>
                        <input type="password" id="login-pin" placeholder="Enter your PIN" maxlength="6" required>
                    </div>
                    <button type="submit" class="btn-submit">Login</button>
                </form>
                <div class="forgot-password">
                    <a href="#" onclick="showForgotPassword()">Forgot Password?</a>
                </div>
            </div>
        </div>

        <!-- Admin Login Page -->
        <div id="admin-login-page" class="page">
            <div class="login-container">
                <div class="login-header">
                    <h2>Admin Login</h2>
                    <p>Global Pilgrim Bank Nigeria - Administrator</p>
                </div>
                <div class="alert" id="admin-login-alert"></div>
                <form id="admin-login-form">
                    <div class="form-group">
                        <label>Username</label>
                        <input type="text" id="admin-username" placeholder="Enter username" required>
                    </div>
                    <div class="form-group">
                        <label>Password</label>
                        <input type="password" id="admin-password" placeholder="Enter password" required>
                    </div>
                    <button type="submit" class="btn-submit">Admin Login</button>
                </form>
                <div class="forgot-password">
                    <a href="#" onclick="showForgotPassword()">Forgot Password?</a>
                </div>
            </div>
        </div>

        <!-- Customer Dashboard -->
        <div id="customer-dashboard" class="page">
            <div class="dashboard">
                <div class="sidebar">
                    <ul class="sidebar-menu">
                        <li><a href="#" class="active" onclick="showSection('customer-overview')">Overview</a></li>
                        <li><a href="#" onclick="showSection('customer-transfer')">Transfer</a></li>
                        <li><a href="#" onclick="showSection('customer-crypto')">Crypto Wallet</a></li>
                        <li><a href="#" onclick="showSection('customer-mining')">Mining</a></li>
                        <li><a href="#" onclick="showSection('customer-betting')">Sports Betting</a></li>
                        <li><a href="#" onclick="showSection('customer-investment')">Investment</a></li>
                        <li><a href="#" onclick="showSection('customer-history')">Transaction History</a></li>
                        <li><a href="#" onclick="showSection('customer-profile')">Profile</a></li>
                        <li><a href="#" onclick="logout()">Logout</a></li>
                    </ul>
                </div>
                <div class="main-content">
                    <!-- Overview Section -->
                    <div id="customer-overview" class="content-section active">
                        <h2>Account Overview</h2>
                        <div class="balance-grid" id="customer-balance-grid">
                            <!-- Balances will be loaded here -->
                        </div>
                        <div class="card">
                            <h3>Recent Transactions</h3>
                            <div class="table-container">
                                <table id="customer-recent-transactions">
                                    <thead>
                                        <tr>
                                            <th>Date</th>
                                            <th>Type</th>
                                            <th>Description</th>
                                            <th>Amount</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <!-- Transactions will be loaded here -->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Transfer Section -->
                    <div id="customer-transfer" class="content-section">
                        <h2>Transfer Funds</h2>
                        <div class="card">
                            <h3>Local Transfer</h3>
                            <form id="local-transfer-form">
                                <div class="form-group">
                                    <label>Select Bank</label>
                                    <select id="transfer-bank" required>
                                        <option value="">Select Bank</option>
                                        <option value="044">Access Bank</option>
                                        <option value="058">GTBank</option>
                                        <option value="011">First Bank</option>
                                        <option value="033">UBA</option>
                                        <option value="070">Fidelity Bank</option>
                                        <option value="057">Zenith Bank</option>
                                        <option value="050">Ecobank</option>
                                        <option value="084">Keystone Bank</option>
                                        <option value="221">Stanbic IBTC</option>
                                        <option value="023">Citibank</option>
                                        <option value="999">Global Pilgrim Bank</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label>Account Number</label>
                                    <input type="text" id="transfer-account" placeholder="Enter 10-digit account number" maxlength="10" required>
                                </div>
                                <div class="form-group">
                                    <label>Account Name</label>
                                    <input type="text" id="transfer-name" placeholder="Account name will appear here" readonly>
                                </div>
                                <div class="form-group">
                                    <label>Amount (NGN)</label>
                                    <input type="number" id="transfer-amount" placeholder="Enter amount" min="1" required>
                                </div>
                                <div class="form-group">
                                    <label>Narration</label>
                                    <input type="text" id="transfer-narration" placeholder="Enter narration">
                                </div>
                                <button type="submit" class="btn-submit">Send Money</button>
                            </form>
                        </div>
                        <div class="card">
                            <h3>International Transfer</h3>
                            <form id="international-transfer-form">
                                <div class="form-group">
                                    <label>Country</label>
                                    <select id="intl-country" required>
                                        <option value="">Select Country</option>
                                        <option value="US">United States</option>
                                        <option value="UK">United Kingdom</option>
                                        <option value="EU">Eurozone</option>
                                        <option value="CA">Canada</option>
                                        <option value="AU">Australia</option>
                                        <option value="JP">Japan</option>
                                        <option value="CN">China</option>
                                        <option value="BR">Brazil</option>
                                        <option value="RU">Russia</option>
                                        <option value="SA">South Africa</option>
                                        <option value="GH">Ghana</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label>SWIFT/BIC Code</label>
                                    <input type="text" id="intl-swift" placeholder="Enter SWIFT/BIC code" required>
                                </div>
                                <div class="form-group">
                                    <label>IBAN/Account Number</label>
                                    <input type="text" id="intl-iban" placeholder="Enter IBAN or account number" required>
                                </div>
                                <div class="form-group">
                                    <label>Beneficiary Name</label>
                                    <input type="text" id="intl-name" placeholder="Enter beneficiary name" required>
                                </div>
                                <div class="form-group">
                                    <label>Amount (USD)</label>
                                    <input type="number" id="intl-amount" placeholder="Enter amount in USD" min="1" required>
                                </div>
                                <button type="submit" class="btn-submit">Send International</button>
                            </form>
                        </div>
                    </div>

                    <!-- Crypto Wallet Section -->
                    <div id="customer-crypto" class="content-section">
                        <h2>Crypto Wallet</h2>
                        <div class="mining-grid" id="crypto-wallets">
                            <!-- Crypto wallets will be loaded here -->
                        </div>
                    </div>

                    <!-- Mining Section -->
                    <div id="customer-mining" class="content-section">
                        <h2>Mining Operations</h2>
                        <div class="card">
                            <h3>Active Mining</h3>
                            <div class="mining-grid" id="mining-operations">
                                <!-- Mining operations will be loaded here -->
