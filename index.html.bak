                        <li><a href="#" onclick="showAdminSection('admin-create-customer')">Create Customer</a></li>
                        <li><a href="#" onclick="showAdminSection('admin-transactions')">Transactions</a></li>
                        <li><a href="#" onclick="showAdminSection('admin-approvals')">Approvals</a></li>
                        <li><a href="#" onclick="showAdminSection('admin-mining')">Mining Control</a></li>
                        <li><a href="#" onclick="showAdminSection('admin-terminal')">Terminal</a></li>
                        <li><a href="#" onclick="showAdminSection('admin-settings')">Settings</a></li>
